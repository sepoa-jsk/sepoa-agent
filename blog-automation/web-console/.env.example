# ============================================================
#  web-console 환경설정 견본
#  사용법: 이 파일을 복사해 ".env" 로 만들고, 각 서버 환경에 맞게 값만 바꾼다.
#    Windows:  copy .env.example .env
#    Linux:    cp .env.example .env
#  .env 는 git 에 올리지 않는다 (.gitignore 에 포함).
# ============================================================

# ── 백엔드(하네스) 폴더 경로 ─────────────────────────────────
#  CLAUDE.md·스킬·spec.md 가 들어있는 폴더. Claude Code 가 여기서 실행된다.
#  비워두면 코드가 자동으로 ../backend (콘솔의 형제 폴더) 를 사용한다.
#  다른 위치면 절대경로로 지정한다.
#    Windows 예) BACKEND_DIR=E:\Project\sepoa-agent\blog-automation\backend
#    Linux   예) BACKEND_DIR=/srv/sepoa-agent/blog-automation/backend
BACKEND_DIR=

# ── claude 실행 파일 경로 ───────────────────────────────────
#  claude Code CLI 를 실행하는 명령/경로.
#  비워두면 OS 기본값을 쓴다: Windows="claude.cmd", Linux/Mac="claude"
#  (PATH 에 claude 가 있으면 그대로 이름만, 없으면 절대경로를 넣는다.)
#    Windows 예) CLAUDE_BIN=C:\Users\사용자\AppData\Roaming\npm\claude.cmd
#    Linux   예) CLAUDE_BIN=/usr/local/bin/claude
#            또는 CLAUDE_BIN=/home/deploy/.npm-global/bin/claude
CLAUDE_BIN=

# ── 서버 포트 ───────────────────────────────────────────────
PORT=4317

# ── Claude 실행 파라미터 ────────────────────────────────────
#  한 단계에서 허용할 최대 턴 수 (폭주 방지 안전장치)
MAX_TURNS=30

#  claude 에게 허용할 도구 (콤마로 구분, 공백 없이)
#  이 워크플로에 필요한 최소 범위만 연다.
ALLOWED_TOOLS=Read,Edit,Write,Glob,Grep,Bash(pandoc *),Bash(soffice *)

#  업로드 파일 최대 크기 (MB)
MAX_UPLOAD_MB=20

# ── 기본 Claude 모델 ────────────────────────────────────────
#  화면에서 모델을 안 고르거나 잘못된 값을 보냈을 때 쓸 기본값.
#  허용값: opus, sonnet, haiku, fable 중 하나. 비워두면 claude 자체 기본 모델 사용.
DEFAULT_MODEL=
