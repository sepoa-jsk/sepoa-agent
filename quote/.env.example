# ── quote 견적서 자동생성 시스템 환경설정 ──
# 실제 값은 .env에 채우세요 (.env는 커밋 금지). 기존 sepoa-aidlc-pms와 동일 DB 인스턴스.

# ── 서버 ──
PORT=3100
NODE_ENV=development
# HTTPS 배포 시에만 true (사내 HTTP 배포면 false 유지 — 아니면 로그인 쿠키 저장 안 됨)
COOKIE_SECURE=false
# nginx 등 리버스 프록시 뒤에 있으면 true
TRUST_PROXY=false

# ── MariaDB (aidlc-pms와 동일 인스턴스, sq_ 접두어 테이블) ──
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_CONNECTION_LIMIT=10

# ── 인증 ──
# dev: Google 없이 개발용 로그인 허용 / google: 실 SSO
AUTH_MODE=dev
SESSION_SECRET=change-me-in-production
# Google OAuth 2.0 Client ID (Google Cloud Console 발급 후 입력)
GOOGLE_CLIENT_ID=
# 로그인 허용 도메인 (쉼표 구분)
ALLOWED_EMAIL_DOMAINS=sepoasoft.co.kr
# 최초 로그인 시 ADMIN으로 부여할 이메일 (쉼표 구분, 선택)
ADMIN_EMAILS=

# ── 타시스템 연계 인증 (X-API-Key 헤더) ──
API_KEY=
